type _ImmutableObjectStorageRefillResult = 
 record {
   success: opt bool;
   topped_up_amount: opt nat;
 };
type _ImmutableObjectStorageRefillInformation = record {
                                                  proposed_top_up_amount:
                                                   opt nat;};
type _ImmutableObjectStorageCreateCertificateResult = 
 record {
   blob_hash: text;
   method: text;
 };
type UploadResult = 
 record {
   characterId: CharacterId;
   imageKey: CharacterImageKey;
 };
type HomebrewItemId = text;
type HomebrewArtResult = 
 record {
   artKey: HomebrewArtKey;
   itemId: HomebrewItemId;
 };
type HomebrewArtKey = text;
type CharacterImageKey = text;
type CharacterId = text;
service : {
  _immutableObjectStorageBlobsAreLive: (hashes: vec blob) -> (vec bool) query;
  _immutableObjectStorageBlobsToDelete: () -> (vec blob) query;
  _immutableObjectStorageConfirmBlobDeletion: (blobs: vec blob) -> ();
  _immutableObjectStorageCreateCertificate: (blobHash: text) ->
   (_ImmutableObjectStorageCreateCertificateResult);
  _immutableObjectStorageRefillCashier: (refillInformation:
   opt _ImmutableObjectStorageRefillInformation) ->
   (_ImmutableObjectStorageRefillResult);
  _immutableObjectStorageUpdateGatewayPrincipals: () -> ();
  deleteCharacterImage: (characterId: CharacterId) -> ();
  deleteHomebrewArt: (itemId: HomebrewItemId) -> ();
  getCharacterImageKey: (characterId: CharacterId) ->
   (opt CharacterImageKey) query;
  getHomebrewArtKey: (itemId: HomebrewItemId) -> (opt HomebrewArtKey) query;
  health: () -> (text) query;
  uploadCharacterImage: (characterId: CharacterId, blobHash:
   CharacterImageKey) -> (UploadResult);
  uploadHomebrewArt: (itemId: HomebrewItemId, artKey: HomebrewArtKey) ->
   (HomebrewArtResult);
}
